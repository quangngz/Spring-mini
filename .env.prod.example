# Production Environment Variables for EC2
# Copy this file to .env on your EC2 instance and update the values

# Docker Hub
DOCKER_USERNAME=your-dockerhub-username
TAG=latest

# Web security
JWT_KEY=your-production-jwt-secret-key-at-least-64-characters-long
JWT_EXPIRY_MS=300000

# AWS S3
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key
S3_BUCKET_NAME=your-s3-bucket
S3_REGION=your-s3-region

# PostgreSQL
POSTGRES_DB_NAME=mini
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=your-strong-db-password

# CORS - Update with your actual domain or EC2 public IP
# Example: http://your-domain.com or http://ec2-xx-xx-xx-xx.compute.amazonaws.com
CORS_ALLOWED_ORIGINS=http://your-ec2-public-ip
